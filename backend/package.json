{
  "name": "go-svelte-example-backend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "go run github.com/syumai/workers/cmd/workers-assets-gen -mode=go && GOOS=js GOARCH=wasm go build -o ./build/app.wasm ./cmd/api",
    "dev": "wrangler dev --port 8080",
    "start": "wrangler dev --port 8080",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "devDependencies": {
    "wrangler": "^4.73.0"
  }
}
